rules_version = '2';

// CaseTracker is an intentionally no-login, community-trust tool: anyone with
// the link can read and edit competitions, members and teams, and changes sync
// live for everyone. These rules allow exactly that.
//
// Paste this into Firebase Console → Firestore Database → Rules → Publish.
// If you ever want to lock it down, scope the writes behind Firebase Auth.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
